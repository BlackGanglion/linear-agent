LINEAR_WEBHOOK_SECRET=your-webhook-signing-secret
LINEAR_CLIENT_ID=your-oauth-client-id
LINEAR_CLIENT_SECRET=your-oauth-client-secret
LINEAR_REDIRECT_URI=https://your-machine.ts.net/oauth/callback
PORT=3000

# LLM provider: "moonshot" | "claude" (default: moonshot)
LLM_PROVIDER=moonshot

# Moonshot
MOONSHOT_API_KEY=your-moonshot-api-key

# Claude
CLAUDE_API_KEY=your-claude-api-key

# Optional overrides (override provider defaults)
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# MOONSHOT_MODEL=kimi-k2.6
# CLAUDE_BASE_URL=https://api.laozhang.ai/v1
# CLAUDE_MODEL=claude-sonnet-4-6

# Triage filter: skip issues whose number is strictly less than this threshold.
# Unset or 0 disables the filter. Example: 100 means MOV-99 is skipped, MOV-100 is triaged.
# TRIAGE_MIN_ISSUE_NUMBER=0
